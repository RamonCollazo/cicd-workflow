#!/usr/bin/env bash
set -euo pipefail

# Bootstrap Flux on a specific kubectl context against the gitops repo.
#
# Usage:
#   bash kubernetes/setup_gitops <cluster-name> <flux-path>
#
# Required env: DEVPOD_WORKSPACE_ID, GITUSER, GITOPS_REPO

# --- args ---------------------------------------------------------------- #

if [ "$#" -ne 2 ]; then
  echo "Usage: $0 <cluster-name> <flux-path>"
  echo "  e.g. $0 study-tracker-gitops-dev clusters/dev"
  exit 1
fi

CLUSTER_NAME="$1"
FLUX_PATH="$2"

# --- env ----------------------------------------------------------------- #

required_vars=("DEVPOD_WORKSPACE_ID" "GITUSER" "GITOPS_REPO")
missing_vars=()
for var in "${required_vars[@]}"; do
  if [ -z "${!var:-}" ]; then
    missing_vars+=("$var")
  fi
done
if [ ${#missing_vars[@]} -ne 0 ]; then
  echo "Error: required environment variables not set:"
  for var in "${missing_vars[@]}"; do
    echo "  - $var"
  done
  exit 1
fi

# --- key ----------------------------------------------------------------- #

KEY_DIR="/workspaces/${DEVPOD_WORKSPACE_ID}/dev-keys"
KEY_PATH="${KEY_DIR}/cicd_workflow_gitops_deploy_key"

if [ ! -f "${KEY_PATH}" ]; then
  echo "Error: deploy key not found at ${KEY_PATH}"
  echo "Run 'mise run setup-key' to generate it."
  exit 1
fi

# --- bootstrap ----------------------------------------------------------- #

flux bootstrap git \
  --context "k3d-${CLUSTER_NAME}" \
  --url "ssh://git@github.com/${GITUSER}/${GITOPS_REPO}" \
  --branch main \
  --private-key-file "${KEY_PATH}" \
  --path "${FLUX_PATH}"
