#!/usr/bin/env bash
set -euo pipefail

# Bring up a k3d cluster and bootstrap Flux against the gitops repo.
#
# Usage:
#   bash kubernetes/setup_cluster_gitops <cluster-name> <flux-path>
#
# Examples:
#   bash kubernetes/setup_cluster_gitops study-tracker-gitops-dev  clusters/dev
#   bash kubernetes/setup_cluster_gitops study-tracker-gitops-prod clusters/prod
#
# Flux watches <flux-path> in the gitops repo (cicd-workflow-gitops).

# --- args ---------------------------------------------------------------- #

if [ "$#" -ne 2 ]; then
  echo "Usage: $0 <cluster-name> <flux-path>"
  echo "  e.g. $0 study-tracker-gitops-dev clusters/dev"
  exit 1
fi

CLUSTER_NAME="$1"
FLUX_PATH="$2"

# --- colors -------------------------------------------------------------- #

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# --- paths --------------------------------------------------------------- #

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- banner -------------------------------------------------------------- #

echo -e "${GREEN}Study Tracker — GitOps cluster setup${NC}"
echo -e "${YELLOW}Cluster:    ${CLUSTER_NAME}${NC}"
echo -e "${YELLOW}Flux path:  ${FLUX_PATH}${NC}"
echo ""

# --- dependencies -------------------------------------------------------- #

check_dependency() {
  if ! command -v "$1" &>/dev/null; then
    echo -e "${RED}Error: $1 is not installed. Run 'mise install' first.${NC}"
    exit 1
  fi
}

echo "Checking dependencies..."
for tool in k3d kubectl docker flux; do
  check_dependency "$tool"
done
echo -e "${GREEN}All dependencies are installed.${NC}"
echo ""

# --- cluster ------------------------------------------------------------- #

cluster_exists() {
  k3d cluster list -o json | grep -q "\"name\":\"${CLUSTER_NAME}\""
}

if cluster_exists; then
  echo -e "${YELLOW}Cluster ${CLUSTER_NAME} already exists.${NC}"
  read -r -p "Delete and recreate? (y/n): "
  if [[ ${REPLY:-} =~ ^[Yy]$ ]]; then
    echo "Deleting existing cluster..."
    k3d cluster delete "${CLUSTER_NAME}"
  else
    echo "Reusing existing cluster."
  fi
fi

if ! cluster_exists; then
  echo "Creating k3d cluster..."
  k3d cluster create "${CLUSTER_NAME}" \
    --servers 1 \
    --agents 1 \
    --k3s-arg "--disable=traefik@server:*"
  echo -e "${GREEN}Cluster created.${NC}"
fi

# --- flux bootstrap ------------------------------------------------------ #

echo "Bootstrapping Flux..."
"${SCRIPT_DIR}/setup_gitops" "${CLUSTER_NAME}" "${FLUX_PATH}"
echo -e "${GREEN}Flux bootstrap complete.${NC}"

# --- summary ------------------------------------------------------------- #

echo ""
echo -e "${GREEN}Done.${NC}"
echo "Verify with:"
echo -e "  ${YELLOW}flux --context k3d-${CLUSTER_NAME} get all${NC}"
echo "Tear down with:"
echo -e "  ${YELLOW}k3d cluster delete ${CLUSTER_NAME}${NC}"
